{
  "rewrites": [
    {
      "source": "/(manifest.webmanifest|sw.js|favicon.svg|pwa-192x192.png|pwa-512x512.png)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}
