{
  "rewrites": [
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.json" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/pwa-192x192.png", "destination": "/pwa-192x192.png" },
    { "source": "/pwa-512x512.png", "destination": "/pwa-512x512.png" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
