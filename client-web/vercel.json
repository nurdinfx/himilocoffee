{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webmanifest|json|txt|woff|woff2|ttf|eot)).*)",
      "destination": "/index.html"
    }
  ]
}
